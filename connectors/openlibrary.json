{
  "type": "REST",
  "endpoint": "https://openlibrary.org",
  "resources": [
    {
      "name": "Books",
      "displayName": "Books",
      "cacheMinutes": 3600,
      "cacheRawResponse": true,
      "rateLimit": 2,
      "useLookup": false,
      "lookupBatchSize": 3,
      "minSearchLength": 3,
      "searchAsYouType": false,
      "search": {
        "urlPath": "/search.json?q\u003d{q}\u0026limit\u003d50\u0026offset\u003d{p}",
        "resultPath": "$.docs",
        "method": "GET",
        "pagination": {
          "type": "OFFSET",
          "totalCountPath": "$.num_found"
        }
      },
      "lookup": {
        "urlPath": "",
        "resultPath": "$",
        "method": "GET"
      },
      "list": {
        "urlPath": "",
        "resultPath": "$",
        "method": "GET",
        "pagination": {
          "type": "NONE"
        }
      },
      "mapping": [
        {
          "name": "ID",
          "path": "key",
          "type": "UUID",
          "mementoType": "text"
        },
        {
          "name": "Title",
          "path": "title",
          "type": "STRING",
          "mementoType": "text",
          "mementoRole": "name"
        },
        {
          "name": "Author",
          "path": "author_name[*]",
          "type": "STRING",
          "formatter": "{value|join(\", \")}",
          "mementoType": "text",
          "mementoRole": "desc"
        },
        {
          "name": "Cover",
          "path": "cover_i",
          "type": "STRING",
          "formatter": "https://covers.openlibrary.org/b/id/{value}-L.jpg",
          "mementoType": "image",
          "mementoRole": "thumb"
        },
        {
          "name": "Edition count",
          "path": "edition_count",
          "type": "NUMBER",
          "formatter": "",
          "mementoType": "double"
        },
        {
          "name": "First publish year",
          "path": "first_publish_year",
          "type": "NUMBER",
          "formatter": "",
          "mementoType": "double",
          "mementoRole": "status"
        }
      ]
    },
    {
      "name": "Authors",
      "displayName": "Authors",
      "cacheMinutes": 3600,
      "cacheRawResponse": true,
      "rateLimit": 10,
      "useLookup": true,
      "lookupBatchSize": 1,
      "minSearchLength": 3,
      "searchAsYouType": false,
      "search": {
        "urlPath": "/search/authors.json?q\u003d{q}\u0026offset\u003d{p}",
        "resultPath": "$.docs",
        "method": "GET",
        "pagination": {
          "type": "OFFSET",
          "totalCountPath": "$.numFound"
        }
      },
      "lookup": {
        "urlPath": "/authors/{id}.json",
        "resultPath": "$",
        "method": "GET"
      },
      "list": {
        "urlPath": "",
        "resultPath": "$",
        "method": "GET",
        "pagination": {
          "type": "NONE"
        }
      },
      "mapping": [
        {
          "name": "id",
          "path": "$.key",
          "type": "UUID",
          "formatter": "{value | replace(\"/authors/\",\"\")}"
        },
        {
          "name": "Name",
          "path": "$.name",
          "type": "STRING",
          "formatter": ""
        },
        {
          "name": "Birth Date",
          "path": "$.birth_date",
          "type": "STRING",
          "formatter": ""
        },
        {
          "name": "Bio",
          "path": "$.bio.value",
          "type": "STRING",
          "formatter": ""
        },
        {
          "name": "Photo",
          "path": "$.key",
          "type": "STRING",
          "formatter": "https://covers.openlibrary.org/a/olid/{value | replace(\"/authors/\",\"\")}-L.jpg"
        }
      ]
    }
  ],
  "auth": {
    "type": "NONE",
    "keyPlacement": "QUERY"
  },
  "id": "8309e93f-f858-44f8-956b-20908ff85dc2",
  "name": "Open Library",
  "version": "1.0.0",
  "exportDate": 1773466673403,
  "$schema": "memento:connector-config"
}